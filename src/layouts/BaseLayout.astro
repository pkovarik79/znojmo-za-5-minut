---
import "../styles/global.css";

const {
  title = "Znojmo za 5 minut",
  description = "Krátké a srozumitelné shrnutí tiskových zpráv města Znojma."
} = Astro.props;

const nav = [
  { href: "/", label: "Domů" },
  { href: "/articles", label: "Články" },
  { href: "/about", label: "O projektu" }
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="font-sans antialiased">
    <header class="border-b border-stone-200 bg-paper/95">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4">
        <a href="/" class="text-lg font-bold tracking-normal text-moss">Znojmo za 5 minut</a>
        <nav class="flex items-center gap-3 text-sm font-medium text-stone-700">
          {nav.map((item) => (
            <a class="rounded px-2 py-1 hover:bg-stone-100 hover:text-ink" href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-stone-200">
      <div class="mx-auto max-w-5xl px-4 py-8 text-sm text-stone-600">
        Neoficiální komunitní přehled. Zdrojové URL se používají pouze interně pro deduplikaci.
      </div>
    </footer>
  </body>
</html>
