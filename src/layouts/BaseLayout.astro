---
import "../styles/global.css";

const {
  title = "Znojmo za 5 minut",
  description = "Krátké a srozumitelné shrnutí tiskových zpráv města Znojma."
} = Astro.props;

const nav = [
  { href: "/", label: "Přehled" },
  { href: "/articles", label: "Archiv" },
  { href: "/about", label: "O projektu" }
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-[#f7f6f1] font-sans antialiased">
    <header class="border-b border-stone-300 bg-[#fbfaf6]">
      <div class="mx-auto flex max-w-6xl items-center justify-between border-b border-stone-200 px-4 py-2 text-xs text-stone-600">
        <span>Stručný přehled zpráv města Znojma</span>
        <span>Aktualizováno průběžně</span>
      </div>
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-5">
        <a href="/" class="text-2xl font-extrabold tracking-normal text-[#173f2d]">Znojmo za 5 minut</a>
        <nav class="flex items-center gap-1 text-sm font-semibold text-stone-700">
          {nav.map((item) => (
            <a class="px-3 py-2 hover:bg-stone-100 hover:text-ink" href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-stone-300 bg-[#fbfaf6]">
      <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-8 text-sm text-stone-600 md:flex-row md:items-center md:justify-between">
        <span>Neoficiální komunitní přehled tiskových zpráv města Znojma.</span>
        <span>Zdrojové odkazy se veřejně nezobrazují.</span>
      </div>
    </footer>
  </body>
</html>
