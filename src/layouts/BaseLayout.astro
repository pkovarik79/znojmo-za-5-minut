---
import "../styles/global.css";

const {
  title = "Znojmo za 5 minut",
  description = "Krátké a srozumitelné shrnutí tiskových zpráv města Znojma."
} = Astro.props;

const nav = [
  { href: "/", label: "Přehled" },
  { href: "/articles", label: "Archiv" },
  { href: "/about", label: "O projektu" }
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-[#fbfaf7] font-sans text-[#171717] antialiased">
    <header class="border-b border-stone-200 bg-[#fbfaf7]/95">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-5 py-5 md:py-6">
        <a href="/" class="text-[1.7rem] font-black tracking-normal text-[#123d2a] md:text-3xl">Znojmo za 5 minut</a>
        <nav class="flex items-center gap-1 text-sm font-semibold text-stone-700 md:text-base">
          {nav.map((item) => (
            <a class="px-2.5 py-2 hover:text-[#9b3324] md:px-3" href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mt-16 border-t border-stone-200 bg-[#fbfaf7]">
      <div class="mx-auto flex max-w-5xl flex-col gap-2 px-5 py-8 text-sm text-stone-500 md:flex-row md:items-center md:justify-between">
        <span>Znojmo za 5 minut</span>
        <span>Zdroj: Znojmocity.cz</span>
      </div>
    </footer>
  </body>
</html>
