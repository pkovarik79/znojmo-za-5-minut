---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("cs-CZ", { day: "numeric", month: "long", year: "numeric" }).format(new Date(`${date}T12:00:00Z`));
---

<BaseLayout title="Články | Znojmo za 5 minut">
  <section class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="text-4xl font-bold text-ink">Články</h1>
    <div class="mt-8 grid gap-5">
      {articles.map((article) => (
        <article class="rounded border border-stone-200 bg-white p-6">
          <p class="text-sm text-stone-500">Zdroj: {article.data.sourceName}, {formatDate(article.data.sourceDate)}</p>
          <h2 class="mt-2 text-2xl font-bold text-ink">
            <a class="hover:text-brick" href={`/articles/${article.slug}`}>{article.data.title}</a>
          </h2>
          <p class="mt-3 leading-7 text-stone-700">{article.data.excerpt ?? article.data.answerText}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
