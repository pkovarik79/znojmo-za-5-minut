---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("cs-CZ", { day: "numeric", month: "long", year: "numeric" }).format(new Date(`${date}T12:00:00Z`));
---

<BaseLayout title="Články | Znojmo za 5 minut">
  <section class="mx-auto max-w-5xl px-5 py-12 md:py-16">
    <div class="border-b border-stone-200 pb-6">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#9b3324]">Archiv</p>
      <h1 class="mt-4 text-4xl font-black leading-none text-[#171717] md:text-6xl">Všechny články</h1>
    </div>
    <div class="mt-4 divide-y divide-stone-200">
      {articles.map((article) => (
        <article class="grid gap-4 py-8 md:grid-cols-[170px_1fr]">
          <p class="text-sm text-stone-500">{formatDate(article.data.date)}</p>
          <div>
            <p class="text-sm text-stone-500">Zdroj: {article.data.sourceName}, {formatDate(article.data.sourceDate)}</p>
            <h2 class="mt-2 max-w-3xl text-3xl font-black leading-tight text-[#171717]">
              <a class="hover:text-[#9b3324]" href={`/articles/${article.slug}`}>{article.data.title}</a>
            </h2>
            <p class="mt-3 max-w-3xl font-serif text-lg leading-8 text-stone-700">{article.data.excerpt ?? article.data.answerText}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
