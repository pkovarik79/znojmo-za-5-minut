---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("cs-CZ", { day: "numeric", month: "long", year: "numeric" }).format(new Date(`${date}T12:00:00Z`));
---

<BaseLayout title="Články | Znojmo za 5 minut">
  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="border-b border-stone-300 pb-4">
      <p class="text-sm font-semibold uppercase tracking-wide text-[#9b3324]">Archiv</p>
      <h1 class="mt-2 text-4xl font-extrabold text-[#17202a]">Všechny články</h1>
    </div>
    <div class="mt-6 divide-y divide-stone-300">
      {articles.map((article) => (
        <article class="grid gap-4 py-6 md:grid-cols-[170px_1fr]">
          <p class="text-sm text-stone-600">{formatDate(article.data.date)}</p>
          <div>
            <p class="text-sm text-stone-500">Zdroj: {article.data.sourceName}, {formatDate(article.data.sourceDate)}</p>
            <h2 class="mt-2 text-2xl font-extrabold leading-tight text-[#17202a]">
              <a class="hover:text-[#9b3324]" href={`/articles/${article.slug}`}>{article.data.title}</a>
            </h2>
            <p class="mt-3 leading-7 text-stone-700">{article.data.excerpt ?? article.data.answerText}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
