---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("cs-CZ", { day: "numeric", month: "long", year: "numeric" }).format(new Date(`${date}T12:00:00Z`));
---

<BaseLayout>
  <section class="bg-white">
    <div class="mx-auto grid max-w-5xl gap-8 px-4 py-12 md:grid-cols-[1.25fr_0.75fr] md:py-16">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-brick">Tiskové zprávy stručně</p>
        <h1 class="max-w-3xl text-4xl font-bold leading-tight text-ink md:text-5xl">Co se děje ve Znojmě, přečtené za pár minut.</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-stone-700">
          Automatizovaný statický web převádí nové tiskové zprávy města do krátkých návrhů článků. Publikují se jen texty schválené v repozitáři.
        </p>
      </div>
      <aside class="border-l-4 border-moss bg-paper p-5">
        <p class="text-sm font-semibold text-moss">Workflow MVP</p>
        <p class="mt-2 text-sm leading-6 text-stone-700">Scraper najde nové zprávy, OpenAI připraví návrh, GitHub Actions uloží Markdown draft a Cloudflare Pages web sestaví.</p>
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-10">
    <div class="mb-6 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold text-ink">Nejnovější články</h2>
      <a class="text-sm font-semibold text-brick hover:underline" href="/articles">Všechny články</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {articles.map((article) => (
        <article class="rounded border border-stone-200 bg-white p-5">
          <p class="text-sm text-stone-500">{formatDate(article.data.date)}</p>
          <h3 class="mt-2 text-xl font-bold leading-snug text-ink">
            <a class="hover:text-brick" href={`/articles/${article.slug}`}>{article.data.title}</a>
          </h3>
          <p class="mt-3 text-sm leading-6 text-stone-700">{article.data.excerpt ?? article.data.answerText}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
