---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const lead = articles[0];
const secondary = articles.slice(1, 7);

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("cs-CZ", { day: "numeric", month: "long", year: "numeric" }).format(new Date(`${date}T12:00:00Z`));

const publicSourceName = "Znojmocity.cz";
---

<BaseLayout>
  <section class="border-b border-stone-200">
    <div class="mx-auto max-w-5xl px-5 py-12 md:py-16">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#9b3324]">Rychlý přehled pro obyvatele</p>
      <h1 class="mt-5 max-w-4xl text-4xl font-black leading-[0.98] text-[#171717] md:text-6xl">Aktuální zprávy ze Znojma bez úředního šumu.</h1>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-10 md:py-14">
    <div class="mb-8 flex items-end justify-between border-b border-stone-200 pb-4">
      <h2 class="text-2xl font-black text-[#171717]">Aktuálně</h2>
      <a class="text-sm font-bold text-[#9b3324] hover:underline" href="/articles">Archiv článků</a>
    </div>

    {lead && (
      <article class="border-b border-stone-200 pb-9">
        <p class="text-sm font-medium text-stone-500">Zdroj: {publicSourceName}, {formatDate(lead.data.sourceDate)}</p>
        <h3 class="mt-3 max-w-4xl text-3xl font-black leading-[1.04] text-[#171717] md:text-5xl">
          <a class="hover:text-[#9b3324]" href={`/articles/${lead.slug}`}>{lead.data.title}</a>
        </h3>
        <p class="mt-5 max-w-3xl font-serif text-xl leading-9 text-stone-700 md:text-2xl">{lead.data.excerpt ?? lead.data.answerText}</p>
      </article>
    )}

    <div class="divide-y divide-stone-200">
      {secondary.map((article) => (
        <article class="grid gap-4 py-7 md:grid-cols-[150px_1fr]">
          <p class="text-sm text-stone-500">{formatDate(article.data.date)}</p>
          <div>
            <h3 class="max-w-3xl text-2xl font-black leading-tight text-[#171717]">
              <a class="hover:text-[#9b3324]" href={`/articles/${article.slug}`}>{article.data.title}</a>
            </h3>
            <p class="mt-3 max-w-3xl font-serif text-lg leading-8 text-stone-700">{article.data.excerpt ?? article.data.answerText}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
