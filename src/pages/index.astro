---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const lead = articles[0];
const secondary = articles.slice(1, 5);

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("cs-CZ", { day: "numeric", month: "long", year: "numeric" }).format(new Date(`${date}T12:00:00Z`));
---

<BaseLayout>
  <section class="border-b border-stone-300 bg-[#fbfaf6]">
    <div class="mx-auto max-w-6xl px-4 py-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-[#9b3324]">Rychlý přehled pro obyvatele</p>
      <div class="mt-3 grid gap-6 md:grid-cols-[1fr_280px] md:items-end">
        <h1 class="max-w-4xl text-3xl font-extrabold leading-tight text-[#17202a] md:text-5xl">Aktuální zprávy ze Znojma stručně a přehledně.</h1>
        <p class="text-base leading-7 text-stone-700">Krátké redakční shrnutí oficiálních tiskových zpráv. Každý text ukazuje hlavní odpověď, datum a zdroj.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-8 px-4 py-8 lg:grid-cols-[minmax(0,1fr)_320px]">
    <div>
      <div class="mb-4 flex items-center justify-between border-b border-stone-300 pb-3">
        <h2 class="text-xl font-extrabold text-[#17202a]">Aktuálně</h2>
        <a class="text-sm font-semibold text-[#9b3324] hover:underline" href="/articles">Archiv článků</a>
      </div>

      {lead && (
        <article class="border-b border-stone-300 pb-7">
          <p class="text-sm font-medium text-stone-600">Zdroj: {lead.data.sourceName}, {formatDate(lead.data.sourceDate)}</p>
          <h3 class="mt-3 max-w-3xl text-3xl font-extrabold leading-tight text-[#17202a] md:text-4xl">
            <a class="hover:text-[#9b3324]" href={`/articles/${lead.slug}`}>{lead.data.title}</a>
          </h3>
          <p class="mt-4 max-w-2xl text-lg leading-8 text-stone-700">{lead.data.excerpt ?? lead.data.answerText}</p>
          <a class="mt-5 inline-block text-sm font-bold uppercase tracking-wide text-[#9b3324] hover:underline" href={`/articles/${lead.slug}`}>Přečíst stručně</a>
        </article>
      )}

      <div class="divide-y divide-stone-300">
        {secondary.map((article) => (
          <article class="grid gap-3 py-5 md:grid-cols-[140px_1fr]">
            <p class="text-sm text-stone-600">{formatDate(article.data.date)}</p>
            <div>
              <h3 class="text-xl font-bold leading-snug text-[#17202a]">
                <a class="hover:text-[#9b3324]" href={`/articles/${article.slug}`}>{article.data.title}</a>
              </h3>
              <p class="mt-2 leading-7 text-stone-700">{article.data.excerpt ?? article.data.answerText}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <aside class="space-y-6">
      <section class="border-t-4 border-[#173f2d] bg-white p-5 shadow-sm">
        <h2 class="text-base font-extrabold text-[#173f2d]">Co tady najdete</h2>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-stone-700">
          <li>Krátká shrnutí oficiálních zpráv města.</li>
          <li>Jednu hlavní otázku a odpověď u každého článku.</li>
          <li>Datum a název zdroje bez zahlcení odkazy.</li>
        </ul>
      </section>
      <section class="border border-stone-300 bg-[#fbfaf6] p-5">
        <h2 class="text-base font-extrabold text-[#17202a]">Zdroj informací</h2>
        <p class="mt-3 text-sm leading-6 text-stone-700">Texty vycházejí z tiskových zpráv města Znojma. Veřejně publikované články procházejí schválením v repozitáři.</p>
      </section>
    </aside>
  </section>
</BaseLayout>
